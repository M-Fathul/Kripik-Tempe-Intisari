# ──────────────────────────────────────────────────────────────────────────────
# .env.docker.example — Template environment variables untuk Docker Compose
#
# Copy ke .env.docker dan isi sebelum menjalankan docker compose:
#   cp .env.docker.example .env.docker
#
# File ini berisi semua variabel untuk SEMUA services (Laravel + Flask).
# Jangan commit .env.docker ke version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Nginx ─────────────────────────────────────────────────────────────────────
NGINX_PORT=80

# ── Laravel App ───────────────────────────────────────────────────────────────
APP_NAME=Kripik_Tempe_Intisari
APP_ENV=production
APP_KEY=                        # Generate: php artisan key:generate --show
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ── Database (MySQL) ──────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql                   # Nama service di docker-compose.yml
DB_PORT=3306
DB_DATABASE=kripik_tempe_intisari
DB_USERNAME=kti_user
DB_PASSWORD=                    # Ganti dengan password aman
DB_ROOT_PASSWORD=               # Untuk MySQL root (hanya dipakai container init)

# ── Session & Cache ───────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis

# ── Queue ─────────────────────────────────────────────────────────────────────
QUEUE_CONNECTION=redis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis               # Nama service di docker-compose.yml
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Broadcast / Filesystem ───────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

# ── Flask ML Service ──────────────────────────────────────────────────────────
# URL internal Docker — Flask tidak di-expose ke publik
FLASK_API_URL=http://flask:5000/forecast/prophet
# Harus sama dengan FLASK_API_KEY di bawah (Bearer token)
FLASK_API_KEY=                  # Generate: python -c "import secrets; print(secrets.token_hex(32))"

# ── Flask container env vars ──────────────────────────────────────────────────
FLASK_ENV=production
# Harus sama dengan FLASK_API_KEY di atas
FLASK_API_KEY=                  # Copy nilai yang sama dari FLASK_API_KEY Laravel
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=5000

# ── Admin Seeder (dipakai sekali saat migrate --seed) ────────────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=                 # Gunakan password kuat di production

# ── Vite (tidak digunakan di production build, tapi perlu untuk artisan) ─────
VITE_APP_NAME="${APP_NAME}"
